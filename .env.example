OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Telemetry (v0.1 writes locally only — nothing is sent over the network)
# Level 1 execution metrics: anonymous, no content, no PII. Opt-OUT:
AUTONITIA_TELEMETRY=true
# Level 2 dataset capture: full trace + markdown. Opt-IN (off by default):
AUTONITIA_DATASET=false
